ZHIPU_API_KEY=
GLM_MODEL=glm-4-flash
IMAGE_MODEL=glm-image
IMAGE_SIZE=1280x1280
VIDEO_MODEL=cogvideox-3
VIDEO_QUALITY=speed
VIDEO_SIZE=1920x1080
VIDEO_FPS=30
# 开发：仅调用 GLM+选曲，不请求图像/视频
DEBUG_GLM_ONLY=false
# 开发：文生图后停止，不请求清影
DEBUG_STOP_AFTER_IMAGE=false

# --- BGM 与短片对齐（方案 A）---
# 是否启用：silencedetect 找有声起点 + 随机窗 + ffmpeg -ss
MUSIC_ALIGN_ENABLED=true
# silencedetect：低于该分贝视为静音（可酌情调低若总判成静音）
MUSIC_SILENCE_NOISE_DB=-35
# 连续静音至少多长才算一段（秒）
MUSIC_SILENCE_MIN_SEC=0.3
# 检测失败（如无 ffmpeg）时从该秒数切入
MUSIC_FALLBACK_SKIP_SEC=15
# 在有声起点之后，额外随机偏移的上限（秒），且不超过「剩余长度−视频时长」
MUSIC_RANDOM_EXTRA_MAX_SEC=90
# 是否缓存每首歌的「有声起点」到同目录 .mp3.seek_cache.json（随文件 mtime 失效）
MUSIC_SEEK_CACHE=true
